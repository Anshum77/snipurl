# PostgreSQL connection string used by SQLAlchemy (required).
DATABASE_URL=postgresql://username:password@localhost:5432/snipurl

# Base URL used when returning full short URLs in API responses.
APP_BASE_URL=http://127.0.0.1:8000

# Redis connection string (used for caching + rate limiting).
REDIS_URL=redis://localhost:6379/0

# Cache TTL (seconds) for short-code lookups stored in Redis.
REDIS_CACHE_TTL_SECONDS=3600

# Fixed-window size (seconds) for rate limiting.
RATE_LIMIT_WINDOW_SECONDS=60

# Rate limit for POST /shorten (requests per window per IP).
RATE_LIMIT_SHORTEN=5

# Rate limit for GET /{short_code}/stats (requests per window per IP).
RATE_LIMIT_STATS=30

# Rate limit for GET /{short_code} redirects (requests per window per IP).
RATE_LIMIT_REDIRECT=120

# Path to an IP2Location LITE DB11 .BIN file for offline GeoIP enrichment (optional).
GEOIP_DB_PATH=

# Docker Compose note:
# When running via Docker, DATABASE_URL/REDIS_URL are set in compose.yml by default.
